# ──────────────────────────────────────────────────────────────────────────
# Multi-Agent Research & Report Generation Platform — Frontend Environment
# Copy this file to `.env.local` and fill in your own values.
# ──────────────────────────────────────────────────────────────────────────

# ── Backend API ──────────────────────────────────────────────────────────
# Used server-side (next.config.js rewrites) and as a fallback if you ever
# need to call the API directly from a Server Component.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Clerk (Authentication — free tier) ──────────────────────────────────
# Get these from https://dashboard.clerk.com -> your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Optional: customize Clerk's hosted route paths (defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
