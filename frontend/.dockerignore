# ──────────────────────────────────────────────────────────────────────────
# Frontend Docker build context exclusions
# ──────────────────────────────────────────────────────────────────────────

# Secrets — never bake into an image
.env
.env.local
.env.*.local
!.env.local.example

# Dependencies (installed fresh inside the image)
node_modules/
.pnp/
.pnp.js

# Next.js build output (rebuilt inside the image)
.next/
out/
build/
.vercel/

# Version control / editor
.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Docs
README.md
*.md
