# ──────────────────────────────────────────────────────────────────────────
# Multi-Agent Research & Report Generation Platform — Backend Environment
# Copy this file to `.env` and fill in your own values.
# All providers listed below offer a FREE tier.
# ──────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME="Research Platform API"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (Neon PostgreSQL free tier, or local docker-compose postgres) ─
DATABASE_URL=postgresql+asyncpg://research_user:research_pass@localhost:5432/research_platform

# ── Redis (caching + Celery broker) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── ChromaDB (vector store) ─────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=research_knowledge_base

# ── Embedding Model (local, free, runs via sentence-transformers) ──────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── LLM Providers ────────────────────────────────────────────────────────────
# Primary: OpenRouter free models
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=deepseek/deepseek-chat-v3:free
OPENROUTER_MODEL_REASONING=deepseek/deepseek-r1:free
OPENROUTER_MODEL_FAST=qwen/qwen3-8b:free
OPENROUTER_MODEL_ALT=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_LIGHT=google/gemma-3-12b-it:free

# Fallback: Groq free API
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=gemma2-9b-it

# ── Web Search Tools ─────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
# DuckDuckGo Search requires no API key

# ── Authentication (Clerk free tier) ─────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── PDF / Reports ─────────────────────────────────────────────────────────────
REPORTS_STORAGE_PATH=./storage/reports
MAX_REPORT_SOURCES=20

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
